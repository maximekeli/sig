# SIG-SOLS-TOGO-2026-01 — copy to .env
DEBUG=1
SECRET_KEY=change-me-in-production-use-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,web,django,nginx

POSTGRES_DB=sig_sols
POSTGRES_USER=sig_sols
POSTGRES_PASSWORD=sig_sols_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8081

# NASA Earthdata (https://urs.earthdata.nasa.gov/)
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=
# Token JWT Earthdata Login (alternative au mot de passe, expire ~3 mois)
NASA_EARTHDATA_TOKEN=

# Sentinel Hub — https://apps.sentinel-hub.com/ (OAuth client)
# Ne jamais committer les vraies clés : copier dans .env uniquement.
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
# Alias accepté pour le secret :
# SENTINEL_HUB_API_KEY=
# SENTINEL_HUB_TOKEN_URL=https://services.sentinel-hub.com/auth/realms/main/protocol/openid-connect/token

# Rate limiting
THROTTLE_RATE=100/min

# Site
SITE_NAME=SIG Sols Togo
DEFAULT_REGION=maritime

# Email (production — mot de passe oublié)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@sig-sols.tg

# Google Gemini — assistant IA (chatbot sols / parcelles / quiz)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
THROTTLE_ASSISTANT=30/min

# --- Non intégrés dans le code (voir docs/API_EXTERNES.md) ---
# OPENAI_API_KEY=
# MAPBOX_ACCESS_TOKEN=
