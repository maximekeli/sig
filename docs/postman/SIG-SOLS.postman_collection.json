{
  "info": {
    "name": "SIG-SOLS-TOGO-2026-01",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080/api/v1"},
    {"key": "token", "value": ""}
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {"name": "Token", "request": {"method": "POST", "url": "{{baseUrl}}/auth/token/", "body": {"mode": "raw", "raw": "{\"username\":\"agent1\",\"password\":\"agent123\"}"}}},
        {"name": "Register", "request": {"method": "POST", "url": "{{baseUrl}}/auth/register/"}},
        {"name": "Profile", "request": {"method": "GET", "url": "{{baseUrl}}/auth/profile/", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]}}
      ]
    },
    {
      "name": "Soils",
      "item": [
        {"name": "List points light", "request": {"method": "GET", "url": "{{baseUrl}}/points/?light=1"}},
        {"name": "Dashboard stats", "request": {"method": "GET", "url": "{{baseUrl}}/dashboard/stats/"}},
        {"name": "Export CSV", "request": {"method": "GET", "url": "{{baseUrl}}/points/export-csv/"}},
        {"name": "Zones", "request": {"method": "GET", "url": "{{baseUrl}}/zones/"}}
      ]
    },
    {
      "name": "Spatial",
      "item": [
        {"name": "Proximity", "request": {"method": "GET", "url": "{{baseUrl}}/spatial/proximity/?lon=1.25&lat=6.35&radius_m=5000"}},
        {"name": "Vulnerability", "request": {"method": "GET", "url": "{{baseUrl}}/spatial/vulnerability/"}},
        {"name": "Statistics", "request": {"method": "GET", "url": "{{baseUrl}}/spatial/statistics/"}},
        {"name": "SMAP correlation", "request": {"method": "GET", "url": "{{baseUrl}}/spatial/smap-correlation/"}}
      ]
    },
    {
      "name": "NASA",
      "item": [
        {"name": "Layers", "request": {"method": "GET", "url": "{{baseUrl}}/nasa/layers/"}},
        {"name": "Catalog summary", "request": {"method": "GET", "url": "{{baseUrl}}/nasa/catalog/summary/"}}
      ]
    },
    {
      "name": "ML",
      "item": [
        {"name": "Predict", "request": {"method": "POST", "url": "{{baseUrl}}/ml/predict/", "body": {"mode": "raw", "raw": "{\"ph\":6.2,\"humidity_pct\":35,\"soil_type\":\"limoneux\"}"}}},
        {"name": "Metrics", "request": {"method": "GET", "url": "{{baseUrl}}/ml/metrics/"}}
      ]
    },
    {
      "name": "Education",
      "item": [
        {"name": "Sheets", "request": {"method": "GET", "url": "{{baseUrl}}/education/sheets/"}},
        {"name": "Leaderboard", "request": {"method": "GET", "url": "{{baseUrl}}/education/quiz/leaderboard/"}}
      ]
    }
  ]
}
